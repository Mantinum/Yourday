{
  "name": "yourday",
  "private": true,
  "engines": { "node": ">=20" },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "db:migrate": "pnpm prisma migrate dev",
    "db:seed": "pnpm exec ts-node prisma/seed.ts",
    "dev": "pnpm -w dev",
    "build": "pnpm -w build",
    "test": "pnpm -w test",
    "start:worker": "pnpm --filter @yourday/worker start"
  }
}
