# commune
NODE_ENV=development
TZ=Europe/Paris

# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yourday?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Supabase)
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://<your-supabase-project>.supabase.co/auth/v1
SUPABASE_JWKS_URL=https://<your-supabase-project>.supabase.co/auth/v1/keys

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_EUR_DEFAULT=1

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL_PREF=gpt-4o-mini

# Amazon PA-API
AMAZON_PARTNER_TAG=yourtag-21
AMAZON_ACCESS_KEY_ID=AKIA...
AMAZON_SECRET_ACCESS_KEY=...
AMAZON_MARKETPLACE=amazon.fr

# Amazon Incentives (Stub)
AMAZON_INCENTIVES_API_BASE=https://sandbox.amazon.com/incentives
AMAZON_INCENTIVES_API_KEY=stub

# App
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
